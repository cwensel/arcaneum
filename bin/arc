#!/usr/bin/env python3
"""Arc CLI - Semantic and full-text search tools (RDR-001).

This is the main entrypoint for the arc CLI tool, used by:
- Terminal users: bin/arc <command> [options]
- Claude Code agents and plugins
- Automation scripts

All commands are dispatched through arcaneum.cli.main.

For corporate networks with SSL issues, set environment variables in your shell:
  export HF_HUB_OFFLINE=1           # Offline mode
  export PYTHONHTTPSVERIFY=0        # Disable SSL verification

See docs/testing/offline-mode.md for details.
"""

import sys
import os

if __name__ == '__main__':
    # Only mutate sys.path when running as a script, so that importing this
    # file as a module does not shadow an installed `arcaneum` package.
    sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', 'src'))

    from arcaneum.cli.main import main
    sys.exit(main())
